{
    "key": "",
    "manifest_version": 3,
    "name": "uGet Integration",
    "short_name": "uGet",
    "description": "uGet Browser Integration extension replaces default download manager by uGet Download Manager.",
    "version": "3.0.0",
    "minimum_chrome_version": "109.0",
    "homepage_url": "http://ugetdm.com/",
    "offline_enabled": true,
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_icon": "icon_32.png",
        "default_popup": "popup.html"
    },
    "commands": {
        "toggle-interruption": {
            "suggested_key": {
                "default": "Ctrl+Shift+U",
                "mac": "Command+Shift+U"
            },
            "description": "Toggle interruption"
        }
    },
    "icons": {
        "32": "icon_32.png",
        "48": "icon_48.png",
        "64": "icon_64.png",
        "128": "icon_128.png"
    },
    "permissions": [
        "webRequest",
        "nativeMessaging",
        "contextMenus",
        "downloads",
        "storage",
        "cookies",
        "activeTab",
        "tabs",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ]
}
